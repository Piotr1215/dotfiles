[Unit]
Description=Refresh kctx connection health
After=network-online.target
Wants=network-online.target
OnFailure=kctx-health-alert.service

[Service]
Type=oneshot
Environment=PATH=%h/dev/google-cloud-sdk/bin:%h/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=%h/.local/bin/kctx connections refresh --jobs 4
ExecStartPost=-%h/dev/dotfiles/scripts/__kctx_credential_notify.sh
Nice=10
IOSchedulingClass=idle
TimeoutStartSec=10min
StandardOutput=null
StandardError=journal
