(( $+functions[_kctx_commands] )) ||
_kctx_commands() {
    local commands; commands=(
'connections:List connections and cached health' \
'use:Select or release a pane connection' \
'health:Inspect or probe connection health' \
'sources:Inspect and refresh connection sources' \
'current:Show the current connection and namespace' \
'explain:Explain the current connection' \
'run:Run a command using a connection' \
'shell:Open an isolated connection shell' \
'credential:Internal renewable credential helpers used by generated kubeconfigs' \
