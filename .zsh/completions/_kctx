    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:kctx-credential-help-command-$line[1]:"
        case $line[1] in
            (vcluster-token)
_arguments "${_arguments_options[@]}" : \
