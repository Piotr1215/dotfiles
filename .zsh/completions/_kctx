#compdef kctx

autoload -U is-at-least

_kctx() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_kctx_commands" \
"*::: :->kctx" \
&& ret=0
    case $state in
    (kctx)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:kctx-command-$line[1]:"
        case $line[1] in
            (connections)
_arguments "${_arguments_options[@]}" : \
'--output=[Select human-readable table or stable one-id-per-line output]:OUTPUT:(table ids json)' \
'--no-index[Bypass the catalog TTL and perform live source discovery]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(use)
_arguments "${_arguments_options[@]}" : \
'--pane=[Target tmux pane; defaults to TMUX_PANE]:PANE_ID:_default' \
'--no-index[Bypass the catalog TTL and perform live source discovery]' \
'(--no-index)--release[Release this pane; follow direnv or leave KUBECONFIG unset]' \
'-h[Print help]' \
'--help[Print help]' \
'::connection -- Connection id or unambiguous display name; omit it for the picker:_default' \
&& ret=0
;;
(health)
_arguments "${_arguments_options[@]}" : \
'--jobs=[Maximum parallel probes for --refresh]:N:_default' \
'--output=[Select human-readable or versioned structured output]:OUTPUT:(text json)' \
'--refresh[Probe every catalog context with bounded parallelism before listing status]' \
'--no-index[Bypass the catalog TTL before resolving a named context]' \
'--strict[Exit unsuccessfully when any catalog connection is not healthy]' \
'-h[Print help]' \
'--help[Print help]' \
'::context_name -- Context to probe; omit it for the overall health summary:_default' \
&& ret=0
;;
(sources)
_arguments "${_arguments_options[@]}" : \
'--output=[Select human-readable or versioned structured output]:OUTPUT:(table json)' \
'-h[Print help]' \
'--help[Print help]' \
":: :_kctx__subcmd__sources_commands" \
"*::: :->sources" \
&& ret=0

    case $state in
    (sources)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:kctx-sources-command-$line[1]:"
        case $line[1] in
            (show)
_arguments "${_arguments_options[@]}" : \
'--output=[Select human-readable or versioned structured output]:OUTPUT:(table json)' \
'-h[Print help]' \
'--help[Print help]' \
':source -- Source id, for example `gke/loft-prod`:_default' \
&& ret=0
;;
(refresh)
_arguments "${_arguments_options[@]}" : \
'--output=[Select human-readable or versioned structured output]:OUTPUT:(table json)' \
'--background[Exit successfully when another refresh already holds the catalog lock]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_kctx__subcmd__sources__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:kctx-sources-help-command-$line[1]:"
        case $line[1] in
            (show)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(refresh)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
;;
(current)
_arguments "${_arguments_options[@]}" : \
'--output=[Select the human summary or one stable field]:OUTPUT:(summary id label namespace json)' \
